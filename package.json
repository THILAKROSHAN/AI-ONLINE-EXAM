{
  "name": "ai-examination-portal",
  "version": "1.0.0",
  "description": "AI Examination Portal with Firebase, React, and Gemini AI",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "build:production": "vite build --mode production",
    "preview": "vite preview",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write src",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:storage": "firebase deploy --only storage",
    "deploy:production": "npm run build:production && firebase deploy --only hosting --project production",
    "deploy:staging": "npm run build:staging && firebase deploy --only hosting --project staging",
    "emulators": "firebase emulators:start",
    "emulators:auth": "firebase emulators:start --only auth",
    "emulators:firestore": "firebase emulators:start --only firestore",
    "emulators:functions": "firebase emulators:start --only functions",
    "emulators:storage": "firebase emulators:start --only storage",
    "clean": "rm -rf dist node_modules functions/node_modules",
    "build:clean": "npm run clean && npm install && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@google/generative-ai": "^0.1.3",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "chart.js": "^4.5.1",
    "date-fns": "^4.4.0",
    "firebase": "^12.16.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.81.0",
    "react-hot-toast": "^2.6.0",
    "react-idle-timer": "^5.7.3",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "firebase-tools": "^13.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.1.4"
  }
}
